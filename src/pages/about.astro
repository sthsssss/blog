---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "About";

const interests = [
  "Thick clients / desktop application architecture",
  "D3D12 / low-level graphics programming",
  "Systems programming & performance",
  "Rendering pipelines",
  "Real-time graphics",
];

const career = [
  { company: "현대로템 (Hyundai Rotem)", years: "2025" },
  { company: "세나클 (CenaCle)", years: "2026~" },
];
---

<BaseLayout pageTitle={pageTitle}>
  <section>
    <h2>About</h2>
    <p>
      Technical blog focused on systems and graphics.
    </p>
  </section>

  <section>
    <h3>Interests</h3>
    <ul>
      {interests.map((i) => (
        <li>{i}</li>
      ))}
    </ul>
  </section>

  <section>
    <h3>Career</h3>
    <ul>
      {career.map((c) => (
        <li>
          <strong>{c.company}</strong>&nbsp;— <span>{c.years}</span>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
