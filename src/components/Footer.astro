<style>
  footer {
    margin-top: 3rem;
    padding: 1.5rem 1rem;
    border-top: 1px solid #e5e5e5;
    background-color: #fafafa;
    text-align: center;
  }
  
  .footer-content {
    max-width: 900px;
    margin: 0 auto;
  }
  
  .social-icons {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background-color: #e8e8e8;
    border-radius: 50%;
    text-decoration: none;
    color: #1a1a1a;
    transition: background-color 0.3s;
    padding: 0;
  }
  
  .social-link:hover {
    background-color: #d0d0d0;
  }
  
  .social-link svg {
    width: 12px;
    height: 12px;
  }
  
  .footer-text {
    color: #666;
    font-size: 0.85rem;
    margin: 0;
  }
</style>

